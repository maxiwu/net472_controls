<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:CustomDataGrid.Controls"
                    xmlns:converters="clr-namespace:CustomDataGrid.Converters"
                    xmlns:selectors="clr-namespace:CustomDataGrid.Selectors">

    <!--
        Theme brushes (Task 7.3). Exposed as keyed resources so a consuming
        application can override any of them by redefining the same key in a
        higher-priority resource dictionary.
    -->
    <SolidColorBrush x:Key="GridHighlightBrush" Color="#FFFEF6D8" />
    <SolidColorBrush x:Key="GridSelectionBrush" Color="#FFCCE5FF" />
    <SolidColorBrush x:Key="GridDisabledBrush" Color="#FFF0F0F0" />
    <SolidColorBrush x:Key="GridDisabledForegroundBrush" Color="#FFA0A0A0" />
    <SolidColorBrush x:Key="GridEditingBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="GridGroupRowBrush" Color="#FFEDEDED" />
    <SolidColorBrush x:Key="GridRowSeparatorBrush" Color="#FFE0E0E0" />

    <!--
        Cell style (Task 7.2). Applied to every data cell ContentControl built by
        GridCellsPanel. Visual states are driven by the GridCell.* attached
        properties the panel stamps onto each cell (it cannot use a one-shot
        StyleSelector — see Task 7.2 notes). Order matters: editing wins over
        highlight, disabled wins over both.
    -->
    <Style x:Key="GridCellStyle" TargetType="{x:Type ContentControl}">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="0" />
        <Style.Triggers>
            <Trigger Property="controls:GridCell.IsRowHighlighted" Value="True">
                <Setter Property="Background" Value="{DynamicResource GridHighlightBrush}" />
            </Trigger>
            <Trigger Property="controls:GridCell.IsEditing" Value="True">
                <Setter Property="Background" Value="{DynamicResource GridEditingBrush}" />
            </Trigger>
            <Trigger Property="controls:GridCell.IsRowDisabled" Value="True">
                <Setter Property="Background" Value="{DynamicResource GridDisabledBrush}" />
                <Setter Property="TextElement.Foreground" Value="{DynamicResource GridDisabledForegroundBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--
        GridControl default style.

        Virtualization configuration (Task 5.10 — do not change without
        re-running the virtualization sanity checks):
          - VirtualizingPanel.IsVirtualizing = True
          - VirtualizingPanel.VirtualizationMode = Recycling
          - VirtualizingPanel.ScrollUnit = Item
          - ScrollViewer.CanContentScroll = True
        Any of these being wrong silently disables virtualization.
    -->
    <Style TargetType="{x:Type controls:GridControl}">
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        <Setter Property="VirtualizingPanel.ScrollUnit" Value="Item" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        <Setter Property="ItemContainerStyleSelector" Value="{DynamicResource GridRowStyleSelector}" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel
                        IsVirtualizing="True"
                        VirtualizationMode="Recycling"
                        ScrollUnit="Item" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:GridControl}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <controls:GridHeaderBar
                            Grid.Row="0"
                            HeaderActions="{TemplateBinding HeaderActions}" />

                        <controls:GridColumnHeadersPresenter
                            Grid.Row="1"
                            Columns="{TemplateBinding Columns}"
                            HorizontalOffset="{Binding HorizontalOffset, ElementName=PART_Scroll}" />

                        <ScrollViewer
                            x:Name="PART_Scroll"
                            Grid.Row="2"
                            CanContentScroll="True"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto"
                            Focusable="False">
                            <ItemsPresenter />
                        </ScrollViewer>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        GridRowPresenter base/default style — the ItemContainer returned from
        GridControl.GetContainerForItemOverride. The implicit style provides a
        plain fallback; GridRowStyleSelector (below) picks ItemRowStyle or
        GroupRowStyle per row Kind via GridControl.ItemContainerStyleSelector.
    -->
    <Style TargetType="{x:Type controls:GridRowPresenter}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:GridRowPresenter}">
                    <Border x:Name="RowBackground" Background="Transparent">
                        <controls:GridCellsPanel Columns="{TemplateBinding Columns}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ItemRowStyle — a data item row (GridItemRow). The cells panel renders the
        shared columns; the row Border carries selection / highlight / disabled
        visual states. Selection brush applies on IsSelected; highlight on
        IsHighlighted (preserved during edit because nothing here clears it);
        disabled grays the row and blocks interaction via IsHitTestVisible=False.
        Trigger order: selection then highlight then disabled (disabled wins).
    -->
    <Style x:Key="ItemRowStyle" TargetType="{x:Type controls:GridRowPresenter}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:GridRowPresenter}">
                    <Border x:Name="RowBackground"
                            Background="Transparent"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{DynamicResource GridRowSeparatorBrush}">
                        <controls:GridCellsPanel Columns="{TemplateBinding Columns}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter TargetName="RowBackground" Property="Background" Value="{DynamicResource GridSelectionBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                            <Setter TargetName="RowBackground" Property="Background" Value="{DynamicResource GridHighlightBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                            <Setter TargetName="RowBackground" Property="Background" Value="{DynamicResource GridDisabledBrush}" />
                            <Setter TargetName="RowBackground" Property="TextElement.Foreground" Value="{DynamicResource GridDisabledForegroundBrush}" />
                            <Setter Property="IsHitTestVisible" Value="False" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        GroupRowStyle — a group header row (GridGroupRow). Left edge is an
        expand/collapse chevron (Task 7.3) whose Button routes to the grid's
        ExpandGroupCommand / CollapseGroupCommand with the group as parameter;
        the chevron glyph and which command is wired flip on IsExpanded. To its
        right the shared columns render through the same GridCellsPanel (so a
        group row can carry the selection column's tri-state checkbox, an
        editable description, an actions menu, etc.). A disabled group is grayed
        and its chevron is disabled (it cannot expand/collapse).
    -->
    <Style x:Key="GroupRowStyle" TargetType="{x:Type controls:GridRowPresenter}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:GridRowPresenter}">
                    <Border x:Name="RowBackground"
                            Background="{DynamicResource GridGroupRowBrush}"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{DynamicResource GridRowSeparatorBrush}">
                        <DockPanel LastChildFill="True">
                            <!-- Chevron: collapse button shown while expanded -->
                            <Button x:Name="CollapseButton"
                                    DockPanel.Dock="Left"
                                    Width="20"
                                    Focusable="False"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Content="&#x25BE;"
                                    Visibility="Collapsed"
                                    Command="{Binding CollapseGroupCommand, RelativeSource={RelativeSource AncestorType={x:Type controls:GridControl}}}"
                                    CommandParameter="{Binding}" />
                            <!-- Chevron: expand button shown while collapsed -->
                            <Button x:Name="ExpandButton"
                                    DockPanel.Dock="Left"
                                    Width="20"
                                    Focusable="False"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Content="&#x25B8;"
                                    Command="{Binding ExpandGroupCommand, RelativeSource={RelativeSource AncestorType={x:Type controls:GridControl}}}"
                                    CommandParameter="{Binding}" />
                            <controls:GridCellsPanel Columns="{TemplateBinding Columns}" />
                        </DockPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                            <Setter TargetName="ExpandButton" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="CollapseButton" Property="Visibility" Value="Visible" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                            <Setter TargetName="RowBackground" Property="Background" Value="{DynamicResource GridHighlightBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                            <Setter TargetName="RowBackground" Property="Background" Value="{DynamicResource GridDisabledBrush}" />
                            <Setter TargetName="RowBackground" Property="TextElement.Foreground" Value="{DynamicResource GridDisabledForegroundBrush}" />
                            <Setter TargetName="ExpandButton" Property="IsEnabled" Value="False" />
                            <Setter TargetName="CollapseButton" Property="IsEnabled" Value="False" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Row style selector wiring (Task 7.1). Assigned to
        GridControl.ItemContainerStyleSelector in the GridControl style above so
        each realized GridRowPresenter gets ItemRowStyle or GroupRowStyle.
    -->
    <selectors:GridRowStyleSelector x:Key="GridRowStyleSelector"
                                    GroupRowStyle="{StaticResource GroupRowStyle}"
                                    ItemRowStyle="{StaticResource ItemRowStyle}" />

    <!--
        GridColumnHeadersPresenter default style. Lives outside the body
        ScrollViewer (row 1 of the GridControl template) so it never scrolls
        vertically. The internal GridCellsPanel is offset horizontally by
        -HorizontalOffset via a TranslateTransform so the header tracks the
        body's horizontal scroll, while consuming the same Columns collection
        as every row for alignment without any shared-size scope.
    -->
    <Style TargetType="{x:Type controls:GridColumnHeadersPresenter}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:GridColumnHeadersPresenter}">
                    <Border ClipToBounds="True" Background="Transparent">
                        <controls:GridCellsPanel Columns="{TemplateBinding Columns}" IsHeaderPanel="True">
                            <controls:GridCellsPanel.RenderTransform>
                                <TranslateTransform X="{Binding HorizontalOffset, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static converters:NegateDoubleConverter.Instance}}" />
                            </controls:GridCellsPanel.RenderTransform>
                        </controls:GridCellsPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
