<Window x:Class="CustomDataGrid.Sample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cdg="clr-namespace:CustomDataGrid.Controls;assembly=CustomDataGrid"
        xmlns:vm="clr-namespace:CustomDataGrid.Sample.ViewModels"
        Title="CustomDataGrid Sample" Height="640" Width="1024">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="65*" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="35*" />
        </Grid.ColumnDefinitions>

        <!-- ============ Left: grid + toggles ============ -->
        <DockPanel Grid.Column="0">
            <!-- Toggle strip (Task 8.0). Add Group / Delete Selected render in the
                 grid's own header bar via HeaderActions. -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                <CheckBox Content="Single expand mode"
                          IsChecked="{Binding SingleExpandMode, Mode=TwoWay}"
                          VerticalAlignment="Center" Margin="0,0,16,0" />
                <CheckBox Content="Show selection column"
                          IsChecked="{Binding ShowSelectionColumn, Mode=TwoWay}"
                          VerticalAlignment="Center" />
            </StackPanel>

            <Border BorderBrush="#FFCCCCCC" BorderThickness="1">
                <cdg:GridControl x:Name="Grid"
                                 DataSource="{Binding DataSource}"
                                 Columns="{Binding Columns}"
                                 HeaderActions="{Binding HeaderActions}"
                                 GroupRowActions="{Binding GroupRowActions}"
                                 ItemRowActions="{Binding ItemRowActions}"
                                 SelectedRow="{Binding SelectedRow, Mode=TwoWay}"
                                 SelectedRows="{Binding SelectedRows, Mode=OneWay}"
                                 SingleExpandMode="{Binding SingleExpandMode, Mode=TwoWay}"
                                 ShowSelectionColumn="{Binding ShowSelectionColumn, Mode=TwoWay}" />
            </Border>
        </DockPanel>

        <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"
                      Background="Transparent" />

        <!-- ============ Right: event log ============ -->
        <DockPanel Grid.Column="2">
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                <TextBlock Text="Event Log" FontWeight="Bold" VerticalAlignment="Center" />
                <Button Content="Clear Log" DockPanel.Dock="Right"
                        Command="{Binding ClearLogCommand}" Padding="8,2" />
                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,10,0"
                           Foreground="#FF666666">
                    <Run Text="{Binding Log.EntryCount, Mode=OneWay}" />
                    <Run Text=" events" />
                </TextBlock>
            </DockPanel>

            <Border BorderBrush="#FFCCCCCC" BorderThickness="1">
                <ListBox ItemsSource="{Binding Log.Entries}"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="64" />
                                    <ColumnDefinition Width="72" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Timestamp, StringFormat=HH:mm:ss}"
                                           Foreground="#FF888888"
                                           FontFamily="Consolas" />
                                <Border Grid.Column="1" CornerRadius="3" Margin="2,0,6,0"
                                        Padding="4,0" HorizontalAlignment="Left"
                                        Background="{Binding Category, Converter={x:Static vm:LogCategoryToBrushConverter.Instance}}">
                                    <TextBlock Text="{Binding Category}" Foreground="White"
                                               FontSize="11" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Grid.Column="2" Text="{Binding Message}"
                                           TextWrapping="Wrap" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </DockPanel>
    </Grid>
</Window>
